# =============================================================================
# KioskAPI — przyklad konfiguracji (.env)
# Skopiuj do .env i uzupelnij wartosci lokalne.
# =============================================================================

# --- Aplikacja ---
APP_NAME=KioskAPI
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# --- Serwer ---
HOST=0.0.0.0
PORT=8000

# --- PostgreSQL (docker compose) ---
POSTGRES_USER=kiosk
POSTGRES_PASSWORD=kiosk
POSTGRES_DB=kiosk
POSTGRES_PORT=5432

# Format SQLAlchemy: postgresql+psycopg://user:password@host:port/dbname
DATABASE_URL=postgresql+psycopg://kiosk:kiosk@localhost:5432/kiosk

# --- Redis / Celery ---
REDIS_URL=redis://localhost:6379/0
# Opcjonalnie — domyslnie uzywa REDIS_URL
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0

# --- Kiosk (naglowek X-Kiosk-Token) ---
# Min. 16 znakow. Placeholder dziala tylko lokalnie; produkcja wymaga losowego tokenu.
KIOSK_TOKEN=change-me-kiosk-token-min-16-chars

# --- JWT ---
# Min. 32 znaki. Placeholder dziala tylko lokalnie; produkcja wymaga losowego sekretu.
JWT_SECRET_KEY=change-me-jwt-secret-key-min-32-characters-long
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Numer startowy ---
START_NUMBER_TIMEZONE=Europe/Warsaw

# --- Drukarka LAN ---
PRINTER_NAME=default
PRINT_ENABLED=true

# --- Pliki lokalne ---
STORAGE_ROOT=./storage
PDF_STORAGE_DIR=pdfs
SIGNATURE_STORAGE_DIR=signatures
FORM_TEMPLATES_DIR=./templates/forms

# --- E-mail (reset hasla) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=60

# --- Bezpieczenstwo logowania ---
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# --- Kiosk UX ---
KIOSK_IDLE_LOGOUT_SECONDS=90
