# =============================================================================
# KioskAPI — przyklad konfiguracji (.env)
# Skopiuj do .env i uzupelnij wartosci lokalne.
# =============================================================================

# --- Aplikacja ---
APP_NAME=KioskAPI
APP_VERSION=0.1.0
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# --- Serwer ---
HOST=0.0.0.0
PORT=8000

# --- PostgreSQL (docker compose) ---
POSTGRES_USER=kiosk
POSTGRES_PASSWORD=kiosk
POSTGRES_DB=kiosk
POSTGRES_PORT=5432

# Format SQLAlchemy: postgresql+psycopg_async://user:password@host:port/dbname
# Lokalnie (bez Dockera):
DATABASE_URL=postgresql+psycopg_async://kiosk:kiosk@localhost:5432/kiosk
# W Docker Compose host bazy to "db" (ustawiane automatycznie w docker-compose.yml):
# DATABASE_URL=ppostgresql+psycopg_async://kiosk:kiosk@db:5432/kiosk

# --- Kiosk (naglowek X-Kiosk-Token) ---
# Min. 16 znakow. Placeholder dziala tylko lokalnie; produkcja wymaga losowego tokenu.
KIOSK_TOKEN=change-me-kiosk-token-min-16-chars

# --- JWT ---
# Min. 32 znaki. Placeholder dziala tylko lokalnie; produkcja wymaga losowego sekretu.
JWT_SECRET_KEY=change-me-jwt-secret-key-min-32-characters-long
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_HTTPONLY=true
AUTH_COOKIE_SAMESITE=strict
TRUSTED_HOSTS=["*"]

# --- Numer startowy ---
START_NUMBER_TIMEZONE=Europe/Warsaw

# --- Drukarka LAN ---
PRINTER_NAME=default
# PRINTER_HOST=localhost
# PRINTER_PORT=9100
# Samodzielny druk użytkownika po wysłaniu formularza (auto-druk w tle).
# false = druk tylko z panelu admina; true = użytkownik dostaje wydruk od razu po rejestracji.
PRINT_ENABLED=true

# --- Pliki lokalne ---
STORAGE_ROOT=./storage
PDF_STORAGE_DIR=pdfs
SIGNATURE_STORAGE_DIR=signatures
FORM_TEMPLATES_DIR=./templates/forms

# --- Bezpieczenstwo logowania ---
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
LOGIN_RATE_LIMIT_WINDOW_SECONDS=60
LOGIN_RATE_LIMIT_MAX_REQUESTS=10

# --- Kiosk UX ---
KIOSK_IDLE_LOGOUT_SECONDS=30

# --- Frontend React (Vite, usługa node w docker compose) ---
VITE_API_BASE_URL=/api/v1
