# Skopiuj do frontend/.env lub ustaw w docker-compose (usługa node).
# Token musi być zgodny z KIOSK_TOKEN w głównym .env backendu.
VITE_KIOSK_TOKEN=change-me-kiosk-token-min-16-chars
VITE_API_BASE_URL=/api/v1

# Tylko dla proxy Vite w dev (domyślnie host.docker.internal:8000)
# VITE_API_PROXY_TARGET=http://host.docker.internal:8000
