# Skopiuj do frontend/.env lub ustaw w docker-compose (usługa node).
# Nie umieszczaj KIOSK_TOKEN w frontendzie.
# Nagłówek X-Kiosk-Token powinien być wstrzykiwany po stronie reverse proxy (np. Caddy).
VITE_API_BASE_URL=/api/v1
# Przy HTTPS nie ustawiaj URL-a z http:// bo przeglądarka zablokuje mixed content.

# ACC-218: Czas bezczynności (w sekundach), po którym nastąpi automatyczne wylogowanie z sesji
VITE_KIOSK_IDLE_LOGOUT_SECONDS=30

# Tylko dla proxy Vite w dev (domyślnie host.docker.internal:8000)
# VITE_API_PROXY_TARGET=http://host.docker.internal:8000
